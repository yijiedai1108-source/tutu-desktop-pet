+// 哭哭時跟著兔兔的「布丁對話框」：點布丁＝餵食
+class PuddingBubble : public QWidget {
+public:
+    ShijimaWidget *target = nullptr;
+    void setMode(int mode) {
+        if (m_mode != mode) {
+            m_mode = mode;
+            update();
+        }
+    }
+    void setProgress(double progress) {
+        if (m_progress != progress) {
+            m_progress = progress;
+            update();
+        }
+    }
+    void setFood(int food) {
+        if (m_food != food) {
+            m_food = food;
+            update();
+        }
+    }
+private:
+    int m_mode = 0; // 0 食物、1 水杯
+    int m_food = 0; // 想吃的菜（FOOD_TABLE 索引）
+    double m_progress = 0; // 今日飲水達成率 0~1
+public:
+    PuddingBubble(): QWidget(nullptr) {
+        setAttribute(Qt::WA_TranslucentBackground);
+        setAttribute(Qt::WA_NoSystemBackground);
+        setAttribute(Qt::WA_ShowWithoutActivating);
+        Qt::WindowFlags flags = Qt::WindowStaysOnTopHint | Qt::FramelessWindowHint
+            | Qt::WindowDoesNotAcceptFocus | Qt::NoDropShadowWindowHint;
+        #if defined(__APPLE__)
+        flags |= Qt::Window;
+        #else
+        flags |= Qt::Tool;
+        #endif
+        setWindowFlags(flags);
+        setFixedSize(60, 66);
+        setCursor(Qt::PointingHandCursor);
+        startTimer(80);
+    }
+protected:
+    void timerEvent(QTimerEvent *) override {
+        if (!isVisible()) {
+            return;
+        }
+        auto &list = ShijimaManager::defaultManager()->mascots();
+        if (list.empty()) {
+            hide();
+            return;
+        }
+        auto w = list.front();
+        target = w;
+        move(w->x() + w->width() / 2 - width() / 2, w->y() - height() + 10);
+    }
+    void mousePressEvent(QMouseEvent *event) override {
+        auto manager = ShijimaManager::defaultManager();
+        if (m_mode == 1) {
+            QMenu menu;
+            menu.addAction("一小口 100 ml", [this, manager](){
+                manager->drink(target, 100);
+            });
+            menu.addAction("一杯 250 ml", [this, manager](){
+                manager->drink(target, 250);
+            });
+            menu.addAction("一瓶 500 ml", [this, manager](){
+                manager->drink(target, 500);
+            });
+            menu.exec(mapToGlobal(event->pos()));
+        }
+        else if (manager->unlockedFoods() <= 1) {
+            manager->feed(target);
+        }
+        else {
+            QMenu menu;
+            for (int i = 0; i < manager->unlockedFoods(); i++) {
+                menu.addAction(ShijimaManager::foodLabel(i), [this, manager, i](){
+                    manager->feed(target, i);
+                });
+            }
+            if (manager->unlockedFoods() < ShijimaManager::foodCount()) {
+                int next = manager->unlockedFoods();
+                auto locked = menu.addAction(QStringLiteral("Lv.%1 解鎖 %2")
+                    .arg(next + 1).arg(ShijimaManager::foodLabel(next)));
+                locked->setEnabled(false);
+            }
+            menu.exec(mapToGlobal(event->pos()));
+        }
+    }
+    void paintEvent(QPaintEvent *) override {
+        QPainter p(this);
+        p.setRenderHint(QPainter::Antialiasing);
+        QColor line(0x59, 0x50, 0x4A);
+        // 泡泡：框＋尾巴做布林聯集成單一形狀，一次描邊 → 真無縫
+        p.setPen(QPen(line, 2.4));
+        p.setBrush(Qt::white);
+        QPainterPath rectPath;
+        rectPath.addRoundedRect(QRectF(2.5, 2.5, 55, 46), 13, 13);
+        QPainterPath tailPath;
+        QPolygonF tail;
+        tail << QPointF(22, 42) << QPointF(38, 42) << QPointF(30, 62);
+        tailPath.addPolygon(tail);
+        tailPath.closeSubpath();
+        p.drawPath(rectPath.united(tailPath));
+        if (m_mode == 1) {
+            // 水杯：水位 = 今日達成率
+            double topY = 13, botY = 33;
+            double topW = 17, botW = 13;
+            QPointF c(26, 0);
+            QPolygonF cup;
+            cup << QPointF(c.x()-topW/2, topY) << QPointF(c.x()+topW/2, topY)
+                << QPointF(c.x()+botW/2, botY) << QPointF(c.x()-botW/2, botY);
+            p.setPen(QPen(line, 2.2));
+            p.setBrush(Qt::white);
+            p.drawPolygon(cup);
+            double lv = m_progress < 0.08 ? 0.08 : (m_progress > 1 ? 1 : m_progress);
+            double wy = botY - (botY - topY - 1.5) * lv;
+            double t = (wy - topY) / (botY - topY);
+            double sw = topW + (botW - topW) * t;
+            QPolygonF water;
+            water << QPointF(c.x()-sw/2+1, wy) << QPointF(c.x()+sw/2-1, wy)
+                << QPointF(c.x()+botW/2-1, botY-1) << QPointF(c.x()-botW/2+1, botY-1);
+            p.setPen(Qt::NoPen);
+            p.setBrush(QColor(0x96, 0xCD, 0xF5));
+            p.drawPolygon(water);
+            p.setBrush(QColor(0xFF, 0xF8, 0xE1));
+            p.drawEllipse(QRectF(c.x()-5, topY + 3, 3, botY - topY - 7));
+            // 達成率
+            QFont f = p.font();
+            f.setPixelSize(13);
+            f.setBold(true);
+            p.setFont(f);
+            p.setPen(QPen(line, 1));
+            p.drawText(QRectF(0, 34, 60, 13), Qt::AlignCenter,
+                QString::number((int)(m_progress * 100)) + "%");
+            return;
+        }
+        drawFood(p, line);
+    }
+    void drawFood(QPainter &p, QColor const& line) {
+        switch (m_food) {
+        default:
+        case 0: { // 布丁
+            QPolygonF body;
+            body << QPointF(19, 17) << QPointF(41, 17)
+                 << QPointF(46, 37) << QPointF(14, 37);
+            p.setPen(Qt::NoPen);
+            p.setBrush(QColor(0xFF, 0xE0, 0x82));
+            p.drawPolygon(body);
+            QPolygonF cap;
+            cap << QPointF(19, 17) << QPointF(41, 17)
+                << QPointF(43, 25.5) << QPointF(17, 25.5);
+            p.setBrush(QColor(0xA6, 0x6E, 0x3D));
+            p.drawPolygon(cap);
+            for (auto fx : { 22.0, 30.0, 38.0 }) {
+                p.drawEllipse(QPointF(fx, 25.5), 2.0, 2.0);
+            }
+            p.setPen(QPen(line, 2.2));
+            p.setBrush(Qt::NoBrush);
+            p.drawPolygon(body);
+            p.setPen(Qt::NoPen);
+            p.setBrush(QColor(0xFF, 0xF8, 0xE1));
+            p.drawEllipse(QRectF(20, 28, 4.5, 7));
+            break;
+        }
+        case 1: { // 飯糰
+            QPolygonF tri;
+            tri << QPointF(30, 13) << QPointF(44, 36) << QPointF(16, 36);
+            p.setPen(QPen(line, 3.2, Qt::SolidLine, Qt::RoundCap, Qt::RoundJoin));
+            p.setBrush(Qt::white);
+            p.drawPolygon(tri);
+            p.setPen(QPen(line, 1.6));
+            p.setBrush(QColor(0x34, 0x42, 0x34));
+            p.drawRoundedRect(QRectF(25, 27, 10, 9.5), 1.5, 1.5);
+            break;
+        }
+        case 2: { // 郎拉麵
+            p.setPen(QPen(line, 2.2));
+            p.setBrush(Qt::white);
+            p.drawChord(QRectF(13, 9, 34, 27), 180 * 16, 180 * 16);
+            p.setPen(Qt::NoPen);
+            p.setBrush(QColor(0xD6, 0x54, 0x4C));
+            p.drawRect(QRectF(19, 28.5, 22, 2.4));
+            p.setPen(QPen(line, 2.2));
+            p.setBrush(QColor(0xF7, 0xD2, 0x78));
+            p.drawEllipse(QRectF(13, 18.4, 34, 8.4));
+            p.setPen(QPen(line, 1.2));
+            p.setBrush(Qt::NoBrush);
+            for (auto fx : { 19.0, 26.0, 33.0 }) {
+                p.drawArc(QRectF(fx, 20.8, 5.5, 3.2), 0, 180 * 16);
+            }
+            p.setPen(QPen(QColor(185, 185, 185), 1.6));
+            for (auto fx : { 24.0, 34.0 }) {
+                p.drawArc(QRectF(fx, 8, 3.4, 8), 90 * 16, 180 * 16);
+            }
+            break;
+        }
+        case 3: { // 草莓蛋糕
+            p.setPen(QPen(line, 2));
+            p.setBrush(QColor(0xFA, 0xE3, 0xA0));
+            p.drawRoundedRect(QRectF(18, 21.5, 24, 15), 1.5, 1.5);
+            p.setPen(Qt::NoPen);
+            p.setBrush(Qt::white);
+            p.drawRect(QRectF(19, 27, 22, 4));
+            p.setPen(QPen(line, 2));
+            p.drawRoundedRect(QRectF(16.5, 17.5, 27, 6), 3, 3);
+            for (auto fx : { 22.0, 29.0, 36.0 }) {
+                p.setPen(QPen(line, 1.4));
+                p.setBrush(Qt::white);
+                p.drawEllipse(QRectF(fx, 21, 3.6, 4.2));
+            }
+            p.setPen(Qt::NoPen);
+            p.setBrush(Qt::white);
+            p.drawRect(QRectF(18, 20, 24, 3));
+            p.setPen(QPen(line, 1.8));
+            p.setBrush(QColor(0xE2, 0x3D, 0x4A));
+            p.drawEllipse(QRectF(26.6, 10.5, 6.8, 7.5));
+            break;
