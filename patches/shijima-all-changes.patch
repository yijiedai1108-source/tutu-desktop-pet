+    { "布丁阿拉摩德 🍨", "EatALaMode" },
+};
+}
+
+void ShijimaManager::feed(ShijimaWidget *widget, int food) {
+    food = std::clamp(food, 0, foodCount() - 1);
+    bool matchedCraving = hungerState() == HungerState::Hungry
+        && food == m_craving;
+    m_hungerSeconds = 0;
+    m_settings.setValue("hunger/seconds", m_hungerSeconds);
+    m_neglectSeconds = 0;
+    addAffection(10 + 2 * food + (matchedCraving ? 8 : 0));
+    if (matchedCraving) {
+        static_cast<SpeechBubble *>(m_speechBubble)->say(
+            QStringLiteral("❤️"), 4000);
+    }
+    if (m_puddingBubble != nullptr) {
+        m_puddingBubble->hide();
+    }
+    if (widget != nullptr && std::find(m_mascots.begin(), m_mascots.end(),
+            widget) == m_mascots.end()) {
+        widget = nullptr;
+    }
+    if (widget != nullptr) {
+        // 吃對應食物 → 開心（素材沒有對應行為時逐層退回）
+        try { widget->mascot().next_behavior(FOOD_TABLE[food].behavior); }
+        catch (...) {
+            try { widget->mascot().next_behavior("Happy"); }
+            catch (...) {
+                try { widget->mascot().next_behavior("ChaseMouse"); }
+                catch (...) {}
+            }
+        }
+    }
+}
+
+void ShijimaManager::drink(ShijimaWidget *widget, int ml) {
+    m_thirstSeconds = 0;
+    bool wasBelowGoal = m_waterMlToday < 2000;
+    m_waterMlToday += ml;
+    addAffection(m_waterMlToday >= 2000 && wasBelowGoal ? 25 : 5);
+    m_settings.setValue("water/thirstSeconds", m_thirstSeconds);
+    m_settings.setValue("water/mlToday", m_waterMlToday);
+    if (m_puddingBubble != nullptr) {
+        m_puddingBubble->hide();
+    }
+    if (widget != nullptr && std::find(m_mascots.begin(), m_mascots.end(),
+            widget) == m_mascots.end()) {
+        widget = nullptr;
+    }
+    if (widget != nullptr) {
+        try { widget->mascot().next_behavior("Drink"); }
+        catch (...) {
+            try { widget->mascot().next_behavior("Happy"); }
+            catch (...) {}
+        }
+    }
+}
