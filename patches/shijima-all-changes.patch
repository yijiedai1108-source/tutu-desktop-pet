 #include "ShijimaManager.hpp"
+#include <QDateTime>
+#include <QPainter>
+#include <QMouseEvent>
+#include <algorithm>
+
+namespace {
+// 哭哭時跟著兔兔的「布丁對話框」：點布丁＝餵食
+class PuddingBubble : public QWidget {
+public:
+    ShijimaWidget *target = nullptr;
+    PuddingBubble(): QWidget(nullptr) {
+        setAttribute(Qt::WA_TranslucentBackground);
+        setAttribute(Qt::WA_NoSystemBackground);
+        setAttribute(Qt::WA_ShowWithoutActivating);
+        Qt::WindowFlags flags = Qt::WindowStaysOnTopHint | Qt::FramelessWindowHint
+            | Qt::WindowDoesNotAcceptFocus | Qt::NoDropShadowWindowHint;
+        #if defined(__APPLE__)
+        flags |= Qt::Window;
+        #else
+        flags |= Qt::Tool;
+        #endif
+        setWindowFlags(flags);
+        setFixedSize(60, 66);
+        setCursor(Qt::PointingHandCursor);
+        startTimer(80);
+    }
+protected:
+    void timerEvent(QTimerEvent *) override {
+        if (!isVisible()) {
+            return;
+        }
+        auto &list = ShijimaManager::defaultManager()->mascots();
+        if (list.empty()) {
+            hide();
+            return;
+        }
+        auto w = list.front();
+        target = w;
+        move(w->x() + w->width() / 2 - width() / 2, w->y() - height() + 10);
+    }
+    void mousePressEvent(QMouseEvent *) override {
+        ShijimaManager::defaultManager()->feed(target);
+    }
+    void paintEvent(QPaintEvent *) override {
+        QPainter p(this);
+        p.setRenderHint(QPainter::Antialiasing);
+        QColor line(0x59, 0x50, 0x4A);
+        // 泡泡（先畫尾巴再蓋圓角矩形，接縫藏在矩形下）
+        p.setPen(QPen(line, 2.4));
+        p.setBrush(Qt::white);
+        QPolygonF tail;
+        tail << QPointF(22, 44) << QPointF(38, 44) << QPointF(30, 62);
+        p.drawPolygon(tail);
+        p.drawRoundedRect(QRectF(2.5, 2.5, 55, 46), 13, 13);
+        // 布丁
+        QPolygonF body;
+        body << QPointF(19, 17) << QPointF(41, 17) << QPointF(46, 37) << QPointF(14, 37);
+        p.setPen(Qt::NoPen);
+        p.setBrush(QColor(0xFF, 0xE0, 0x82));
+        p.drawPolygon(body);
+        QPolygonF cap;
+        cap << QPointF(19, 17) << QPointF(41, 17) << QPointF(43, 25.5) << QPointF(17, 25.5);
+        p.setBrush(QColor(0xA6, 0x6E, 0x3D));
+        p.drawPolygon(cap);
+        for (auto fx : { 22.0, 30.0, 38.0 }) {
+            p.drawEllipse(QPointF(fx, 25.5), 2.0, 2.0);
+        }
+        p.setPen(QPen(line, 2.2));
+        p.setBrush(Qt::NoBrush);
+        p.drawPolygon(body);
+        p.setPen(Qt::NoPen);
+        p.setBrush(QColor(0xFF, 0xF8, 0xE1));
+        p.drawEllipse(QRectF(20, 28, 4.5, 7));
+    }
+};
+}
