+// 系統通知（兔兔被視窗蓋住時也看得到）：macOS 走通知中心，其他平台走系統匣氣泡
+// （Windows 10/11 會顯示原生 toast）。
+void ShijimaManager::notify(QString const& message) {
+#if defined(__APPLE__)
+    QProcess::startDetached("osascript", { "-e",
+        QStringLiteral("display notification \"%1\" with title \"兔兔\"")
+            .arg(message) });
+#else
+    if (m_trayIcon == nullptr) {
+        QPixmap pix { 32, 32 };
+        pix.fill(Qt::transparent);
+        {
+            QPainter painter { &pix };
+            QFont f = painter.font();
+            f.setPixelSize(26);
+            painter.setFont(f);
+            painter.drawText(pix.rect(), Qt::AlignCenter,
+                QString::fromUtf8("🐰"));
+        }
+        m_trayIcon = new QSystemTrayIcon(QIcon { pix }, this);
+        m_trayIcon->setToolTip(QString::fromUtf8("兔兔"));
+        m_trayIcon->show();
+    }
+    m_trayIcon->showMessage(QString::fromUtf8("兔兔"), message);
+#endif
+}
+
+// 兔兔叫聲：從已載入素材包的 sound/ 資料夾找 WAV 播放（QSoundEffect 不吃 mp3）。
+// 右鍵選單「🔊 兔兔叫聲」可整批靜音（sound/enabled）。
+void ShijimaManager::playVoice(QString const& name) {
+    if (!soundEnabled()) {
+        return;
+    }
+    m_voice.searchPaths.clear();
+    for (auto data : m_loadedMascots) {
+        QDir dir { data->imgRoot() };
+        if (dir.exists() && dir.cdUp() && dir.cd("sound")) {
+            m_voice.searchPaths.push_back(dir.path());
+        }
+    }
+    m_voice.play(name);
+}
