+void ShijimaManager::hungerTick() {
+    m_hungerSeconds += 5.0 * m_hungerScale;
+    m_settings.setValue("hunger/seconds", m_hungerSeconds);
+    // 喝水：跨日歸零；未達標才累積口渴
+    QString today = QDate::currentDate().toString(Qt::ISODate);
+    if (m_waterDate != today) {
+        m_waterDate = today;
+        m_waterMlToday = 0;
+        m_thirstSeconds = 0;
+        m_settings.setValue("water/date", m_waterDate);
+        m_settings.setValue("water/mlToday", m_waterMlToday);
+    }
+    if (m_waterMlToday < 2000) {
+        m_thirstSeconds += 5.0 * m_hungerScale;
+        m_settings.setValue("water/thirstSeconds", m_thirstSeconds);
+    }
+
+    // 久坐提醒：每 50 分鐘伸展一下（計時不跨重啟——重開機＝有起來走動）
+    m_sitSeconds += 5.0 * m_hungerScale;
+    if (m_sitSeconds >= 50 * 60) {
+        m_sitSeconds = 0;
+        for (auto mascot : m_mascots) {
+            try { mascot->mascot().next_behavior("Stretch"); }
+            catch (...) {}
+        }
+        notify(QString::fromUtf8("坐好久了，站起來動一動吧 🧘"));
+    }
+
+    // 下班提醒：跨過下班時間那一刻提醒一次（預設 18:00，QSettings workday/end 可改）
+    QTime endTime = QTime::fromString(
+        m_settings.value("workday/end", "18:00").toString(), "HH:mm");
+    QTime nowTime = QTime::currentTime();
+    if (endTime.isValid() && m_lastTickTime.isValid()
+        && m_lastTickTime < endTime && nowTime >= endTime)
+    {
+        notify(QString::fromUtf8("該下班了！辛苦一天了 🎉"));
+        startCelebration();
+    }
+    m_lastTickTime = nowTime;
+
+    // 下班慶祝：20 秒內全場狂奔。每隔約 1.2~2.4 秒，幫每隻兔兔隨機切一個「激烈移動」行為，
+    // 讓全場跑上跑下亂竄。名字用引擎實際載入的英文行為名（見右鍵 Behaviors 選單那份清單）。
+    // 注意：跑/爬類多半是 hidden，所以這裡「不看 hidden」，改用明確白名單挑會動的——
+    // 否則抓非-hidden 會抽到 Eat/Drink/Sit（吃飯喝水坐著）。只挑「從地板就能起跳」的，
+    // 避免硬套需要先在牆/天花板上的行為而立刻掉下來。
+    static const char *const dashCandidates[] = {
+        "RunAlongWorkAreaFloor",       // 沿地板狂奔（左右來回）
+        "CrawlAlongWorkAreaFloor",     // 貼地快爬
+        "WalkAndGrabBottomLeftWall",   // 衝去左牆爬上去
+        "WalkAndGrabBottomRightWall",  // 衝去右牆爬上去
+    };
+    qint64 nowMs = QDateTime::currentMSecsSinceEpoch();
+    if (nowMs < m_celebrateUntilMs) {
+        static bool dashSeeded = false;
+        if (!dashSeeded) { std::srand((unsigned)nowMs); dashSeeded = true; }
+        static qint64 nextDashRerollMs = 0;
+        if (nowMs >= nextDashRerollMs) {
+            nextDashRerollMs = nowMs + 1200 + (std::rand() % 1200);  // 1.2~2.4s
+            for (auto mascot : m_mascots) {
+                try {
+                    // 只從「該兔兔實際擁有」的候選名裡挑，確保 find 一定找得到、不會丟例外
+                    auto flat = mascot->mascot()
+                        .initial_behavior_list().flatten_unconditional();
+                    std::vector<std::string> pool;
+                    for (auto name : dashCandidates) {
+                        for (auto &b : flat) {
+                            if (b->name == name) { pool.push_back(name); break; }
+                        }
+                    }
+                    if (!pool.empty()) {
+                        mascot->mascot().next_behavior(
+                            pool[std::rand() % pool.size()]);
+                    }
+                }
+                catch (...) {}
+            }
+        }
+    }
+
+    // 上班時間（平日 workday.start~end）：兔兔偶爾打電腦陪你工作（約 10 分鐘一次）
+    QTime workStart = QTime::fromString(
+        m_settings.value("workday/start", "09:00").toString(), "HH:mm");
+    bool workHours = QDate::currentDate().dayOfWeek() <= 5
+        && workStart.isValid() && endTime.isValid()
+        && nowTime >= workStart && nowTime < endTime;
+    if (workHours && !m_mascots.empty()
+        && QRandomGenerator::global()->bounded(120) == 0)
+    {
+        try { m_mascots.front()->mascot().next_behavior("Work"); }
+        catch (...) {}
+    }
+
+    // ヤハ彩蛋：隨機喊一聲，好感度越高越常跟你說話（Lv1 約 18 分鐘、Lv5 約 7.5 分鐘一次）
+    int shoutOdds = 240 - affectionLevel() * 30;
+    // 測試模式：SHIJIMA_TEST_SHOUT=1 讓吶喊約 15 秒一次，方便驗證泡泡文字與叫聲的對應
+    if (qEnvironmentVariableIsSet("SHIJIMA_TEST_SHOUT")) {
+        shoutOdds = 3;
+    }
+    if (!m_mascots.empty() && !windowedMode() && !m_puddingBubble->isVisible()
+        && QRandomGenerator::global()->bounded(shoutOdds) == 0)
+    {
+        // 叫聲對應：ヤハ→短促「呀哈」、ウラ 系→「哼!嗚啦~呀哈呀哈」、其餘/撒嬌→「哈咿呀哈」
+        static const struct { const char *text; const char *voice; } shouts[] = {
+            { "ヤハ！",       "yaha.wav" },
+            { "ウラ！",       "ura-yahayaha.wav" },
+            { "ウラヤハ！！", "haiyaha.wav" },
+            { "ウラウラ！",   "ura-yahayaha.wav" },
+        };
+        static const struct { const char *text; const char *voice; } fondShouts[] = {
+            { "うらうら〜❤️", "haiyaha.wav" },
+            { "ヤハ〜❤️",     "haiyaha.wav" },
+        };
+        QString text, voice;
+        if (affectionLevel() >= 3 && QRandomGenerator::global()->bounded(4) == 0) {
+            auto &shout = fondShouts[QRandomGenerator::global()->bounded(2)];
+            text = QString::fromUtf8(shout.text);
+            voice = shout.voice;
+        }
+        else {
+            auto &shout = shouts[QRandomGenerator::global()->bounded(4)];
+            text = QString::fromUtf8(shout.text);
+            voice = shout.voice;
+        }
+        static_cast<SpeechBubble *>(m_speechBubble)->say(text);
+        playVoice(voice);
+    }
+
+    // Lv4+：偶爾想找你玩，追滑鼠（約 25 分鐘一次）
+    if (affectionLevel() >= 4 && !m_mascots.empty()
+        && QRandomGenerator::global()->bounded(300) == 0)
+    {
+        try { m_mascots.front()->mascot().next_behavior("ChaseMouse"); }
+        catch (...) {}
+    }
+
+    // Lv5：每天第一次見面，開心迎接
+    if (affectionLevel() >= 5 && !m_mascots.empty()
+        && m_settings.value("affection/greetDate").toString() != today)
+    {
+        m_settings.setValue("affection/greetDate", today);
+        try { m_mascots.front()->mascot().next_behavior("Happy"); }
+        catch (...) {}
+        static_cast<SpeechBubble *>(m_speechBubble)->say(
+            QString::fromUtf8("ヤハ！"));
+    }
+
+    // 冷落懲罰：放著哭哭不管，每 10 分鐘 -5
+    if (hungerState() == HungerState::Hungry) {
+        m_neglectSeconds += 5.0 * m_hungerScale;
+        if (m_neglectSeconds >= 600) {
+            m_neglectSeconds = 0;
+            addAffection(-5);
+        }
+    }
+
+    auto state = hungerState();
+    bool wantPudding = state == HungerState::Hungry;
+    if (wantPudding && !m_wasHungry) {
+        // 剛餓哭：從已解鎖菜單抽一道想吃的（泡泡圖案會直接顯示）
+        m_craving = QRandomGenerator::global()->bounded(unlockedFoods());
+    }
+    m_wasHungry = wantPudding;
+    bool wantWater = m_thirstSeconds >= 45 * 60 && m_waterMlToday < 2000;
+    auto bubble = static_cast<PuddingBubble *>(m_puddingBubble);
+    bool wantBubble = (wantPudding || wantWater) && !m_mascots.empty()
+        && !windowedMode();
+    if (wantBubble) {
+        bubble->setMode(wantPudding ? 0 : 1);
+        bubble->setFood(m_craving);
+        bubble->setProgress(m_waterMlToday / 2000.0);
+    }
+    if (wantBubble != bubble->isVisible()) {
+        if (wantBubble) {
+            notify(wantPudding
+                ? QStringLiteral("兔兔肚子餓哭哭中，點布丁餵牠 🍮")
+                : QStringLiteral("該喝水囉！今日達成 %1%")
+                    .arg((int)(m_waterMlToday / 2000.0 * 100)));
+        }
+        bubble->setVisible(wantBubble);
+    }
+    if (state == HungerState::Full || m_mascots.empty()) {
+        return;
+    }
+    qint64 now = QDateTime::currentMSecsSinceEpoch();
+    qint64 interval = qMax<qint64>(10,
+        (qint64)((state == HungerState::Hungry ? 40 : 180) / m_hungerScale)) * 1000;
+    if (now - m_lastCryMs >= interval) {
+        m_lastCryMs = now;
+        triggerCry(state == HungerState::Hungry);
+    }
 }
 
