+
+ShijimaManager::HungerState ShijimaManager::hungerState() const {
+    if (m_hungerSeconds >= 120 * 60) return HungerState::Hungry;
+    if (m_hungerSeconds >= 90 * 60) return HungerState::Peckish;
+    return HungerState::Full;
+}
+
+QString ShijimaManager::hungerStatusText() const {
+    switch (hungerState()) {
+        case HungerState::Hungry: return QStringLiteral("😭 哭哭中…快餵我");
+        case HungerState::Peckish: return QStringLiteral("🍞 有點餓了");
+        default: return QStringLiteral("😊 吃飽了");
+    }
+}
+
+void ShijimaManager::feed(ShijimaWidget *widget) {
+    m_hungerSeconds = 0;
+    m_settings.setValue("hunger/seconds", m_hungerSeconds);
+    if (widget != nullptr) {
+        // 慶祝：先播開心表情（瞇眼＋愛心），沒有就退回追滑鼠
+        try { widget->mascot().next_behavior("Happy"); }
+        catch (...) {
+            try { widget->mascot().next_behavior("ChaseMouse"); }
+            catch (...) {}
+        }
+    }
+}
+
+void ShijimaManager::triggerCry(bool all) {
+    for (auto mascot : m_mascots) {
+        try { mascot->mascot().next_behavior("Cry"); }
+        catch (...) {}
+        if (!all) break;
+    }
+}
+
+void ShijimaManager::hungerTick() {
+    m_hungerSeconds += 5.0 * m_hungerScale;
+    m_settings.setValue("hunger/seconds", m_hungerSeconds);
+    auto state = hungerState();
+    if (state == HungerState::Full || m_mascots.empty()) {
+        return;
+    }
+    qint64 now = QDateTime::currentMSecsSinceEpoch();
+    qint64 interval = qMax<qint64>(10,
+        (qint64)((state == HungerState::Hungry ? 40 : 180) / m_hungerScale)) * 1000;
+    if (now - m_lastCryMs >= interval) {
+        m_lastCryMs = now;
+        triggerCry(state == HungerState::Hungry);
+    }
 }
 
