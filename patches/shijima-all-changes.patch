+// 隨機吶喊對話框（ヤハ！ウラ！），數秒後自動消失
+class SpeechBubble : public QWidget {
+public:
+    SpeechBubble(): QWidget(nullptr) {
+        setAttribute(Qt::WA_TranslucentBackground);
+        setAttribute(Qt::WA_NoSystemBackground);
+        setAttribute(Qt::WA_ShowWithoutActivating);
+        Qt::WindowFlags flags = Qt::WindowStaysOnTopHint | Qt::FramelessWindowHint
+            | Qt::WindowDoesNotAcceptFocus | Qt::NoDropShadowWindowHint;
+        #if defined(__APPLE__)
+        flags |= Qt::Window;
+        #else
+        flags |= Qt::Tool;
+        #endif
+        setWindowFlags(flags);
+        startTimer(80);
+    }
+    void say(QString const& text, int durationMs = 3200) {
+        m_text = text;
+        QFont f = font();
+        f.setPixelSize(17);
+        f.setBold(true);
+        setFont(f);
+        QFontMetrics fm(f);
+        setFixedSize(std::max(fm.horizontalAdvance(text) + 30, 52), 56);
+        m_hideAtMs = QDateTime::currentMSecsSinceEpoch() + durationMs;
+        show();
+        update();
+    }
+protected:
+    QString m_text;
+    qint64 m_hideAtMs = 0;
+    void timerEvent(QTimerEvent *) override {
+        if (!isVisible()) {
+            return;
+        }
+        if (QDateTime::currentMSecsSinceEpoch() > m_hideAtMs) {
+            hide();
+            return;
+        }
+        auto &list = ShijimaManager::defaultManager()->mascots();
+        if (list.empty()) {
+            hide();
+            return;
+        }
+        auto w = list.front();
+        int x = w->x() + w->width() / 2 - width() / 2;
+        auto pb = ShijimaManager::defaultManager()->puddingBubble();
+        if (pb != nullptr && pb->isVisible()) {
+            x += 54;   // 讓位給布丁/水杯泡泡
+        }
+        move(x, w->y() - height() + 12);
+    }
+    void mousePressEvent(QMouseEvent *) override {
+        hide();
+    }
+    void paintEvent(QPaintEvent *) override {
+        QPainter p(this);
+        p.setRenderHint(QPainter::Antialiasing);
+        QColor line(0x59, 0x50, 0x4A);
+        p.setPen(QPen(line, 2.4));
+        p.setBrush(Qt::white);
+        QPainterPath rectPath;
+        rectPath.addRoundedRect(QRectF(2.5, 2.5, width() - 5, 36), 12, 12);
+        QPainterPath tailPath;
+        QPolygonF tail;
+        tail << QPointF(width() / 2.0 - 8, 34) << QPointF(width() / 2.0 + 8, 34)
+             << QPointF(width() / 2.0, 52);
+        tailPath.addPolygon(tail);
+        tailPath.closeSubpath();
+        p.drawPath(rectPath.united(tailPath));
+        p.setPen(QPen(line, 1));
+        p.drawText(QRectF(0, 2, width(), 36), Qt::AlignCenter, m_text);
+    }
+};
+}
