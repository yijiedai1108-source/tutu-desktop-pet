+
+ShijimaManager::HungerState ShijimaManager::hungerState() const {
+    if (m_hungerSeconds >= 120 * 60) return HungerState::Hungry;
+    if (m_hungerSeconds >= 90 * 60) return HungerState::Peckish;
+    return HungerState::Full;
+}
+
+QString ShijimaManager::hungerStatusText() const {
+    switch (hungerState()) {
+        case HungerState::Hungry: return QStringLiteral("😭 哭哭中…快餵我");
+        case HungerState::Peckish: return QStringLiteral("🍞 有點餓了");
+        default: return QStringLiteral("😊 吃飽了");
+    }
+}
+
+void ShijimaManager::feed(ShijimaWidget *widget) {
+    m_hungerSeconds = 0;
+    m_settings.setValue("hunger/seconds", m_hungerSeconds);
+    if (m_puddingBubble != nullptr) {
+        m_puddingBubble->hide();
+    }
+    if (widget != nullptr && std::find(m_mascots.begin(), m_mascots.end(),
+            widget) == m_mascots.end()) {
+        widget = nullptr;
+    }
+    if (widget != nullptr) {
+        // 吃布丁 → 開心（素材沒有對應行為時逐層退回）
+        try { widget->mascot().next_behavior("Eat"); }
+        catch (...) {
+            try { widget->mascot().next_behavior("Happy"); }
+            catch (...) {
+                try { widget->mascot().next_behavior("ChaseMouse"); }
+                catch (...) {}
+            }
+        }
+    }
+}
+
+void ShijimaManager::drink(ShijimaWidget *widget, int ml) {
+    m_thirstSeconds = 0;
+    m_waterMlToday += ml;
+    m_settings.setValue("water/thirstSeconds", m_thirstSeconds);
+    m_settings.setValue("water/mlToday", m_waterMlToday);
+    if (m_puddingBubble != nullptr) {
+        m_puddingBubble->hide();
+    }
+    if (widget != nullptr && std::find(m_mascots.begin(), m_mascots.end(),
+            widget) == m_mascots.end()) {
+        widget = nullptr;
+    }
+    if (widget != nullptr) {
+        try { widget->mascot().next_behavior("Drink"); }
+        catch (...) {
+            try { widget->mascot().next_behavior("Happy"); }
+            catch (...) {}
+        }
+    }
+}
+
+QString ShijimaManager::waterStatusText() const {
+    int percent = (int)(m_waterMlToday / 2000.0 * 100);
+    if (m_waterMlToday >= 2000) {
+        return QStringLiteral("💧 今日 %1 ml，達標 ✅").arg(m_waterMlToday);
+    }
+    return QStringLiteral("💧 今日 %1 / 2000 ml（%2%）")
+        .arg(m_waterMlToday).arg(percent);
+}
+
+void ShijimaManager::triggerCry(bool all) {
+    for (auto mascot : m_mascots) {
+        try { mascot->mascot().next_behavior("Cry"); }
+        catch (...) {}
+        if (!all) break;
+    }
+}
+
+void ShijimaManager::hungerTick() {
+    m_hungerSeconds += 5.0 * m_hungerScale;
+    m_settings.setValue("hunger/seconds", m_hungerSeconds);
+    // 喝水：跨日歸零；未達標才累積口渴
+    QString today = QDate::currentDate().toString(Qt::ISODate);
+    if (m_waterDate != today) {
+        m_waterDate = today;
+        m_waterMlToday = 0;
+        m_thirstSeconds = 0;
+        m_settings.setValue("water/date", m_waterDate);
+        m_settings.setValue("water/mlToday", m_waterMlToday);
+    }
+    if (m_waterMlToday < 2000) {
+        m_thirstSeconds += 5.0 * m_hungerScale;
+        m_settings.setValue("water/thirstSeconds", m_thirstSeconds);
+    }
+
+    auto state = hungerState();
+    bool wantPudding = state == HungerState::Hungry;
+    bool wantWater = m_thirstSeconds >= 45 * 60 && m_waterMlToday < 2000;
+    auto bubble = static_cast<PuddingBubble *>(m_puddingBubble);
+    bool wantBubble = (wantPudding || wantWater) && !m_mascots.empty()
+        && !windowedMode();
+    if (wantBubble) {
+        bubble->setMode(wantPudding ? 0 : 1);
+        bubble->setProgress(m_waterMlToday / 2000.0);
+    }
+    if (wantBubble != bubble->isVisible()) {
+        if (wantBubble) {
+            // 同步發 macOS 通知（兔兔被視窗蓋住時也看得到）
+            QString msg = wantPudding
+                ? QStringLiteral("兔兔肚子餓哭哭中，點布丁餵牠 🍮")
+                : QStringLiteral("該喝水囉！今日達成 %1%")
+                    .arg((int)(m_waterMlToday / 2000.0 * 100));
+            QProcess::startDetached("osascript", { "-e",
+                QStringLiteral("display notification \"%1\" with title \"兔兔\"")
+                    .arg(msg) });
+        }
+        bubble->setVisible(wantBubble);
+    }
+    if (state == HungerState::Full || m_mascots.empty()) {
+        return;
+    }
+    qint64 now = QDateTime::currentMSecsSinceEpoch();
+    qint64 interval = qMax<qint64>(10,
+        (qint64)((state == HungerState::Hungry ? 40 : 180) / m_hungerScale)) * 1000;
+    if (now - m_lastCryMs >= interval) {
+        m_lastCryMs = now;
+        triggerCry(state == HungerState::Hungry);
+    }
 }
 
