+ShijimaManager::HungerState ShijimaManager::hungerState() const {
+    if (m_hungerSeconds >= 120 * 60) return HungerState::Hungry;
+    if (m_hungerSeconds >= 90 * 60) return HungerState::Peckish;
+    return HungerState::Full;
+}
